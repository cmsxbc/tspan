#!/bin/bash
set -e

SERVER_URL="${TSPANRUN_SERVER:-http://localhost:8080}"
CLIENT_ID="${TSPANRUN_CLIENT:-}"
ALIAS="${TSPANRUN_ALIAS:-}"
TOKEN="${TSPANRUN_TOKEN:-}"
PID=$$

if [[ -z "$TOKEN" ]]; then
    echo "Error: TSPANRUN_TOKEN is not set" >&2
    exit 1
fi

# If command is long and no alias set, truncate for display
if [[ -z "$ALIAS" && "${#*}" -gt 50 ]]; then
    ALIAS="${*:0:50}..."
fi

# Properly JSON-escape a string value
json_escape() {
    local s="${1-}"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

AUTH_HEADER="Authorization: Bearer $TOKEN"

# Build JSON payload with proper escaping
CMD_ESCAPED=$(json_escape "$*")
ALIAS_ESCAPED=$(json_escape "$ALIAS")
if [[ -n "$CLIENT_ID" ]]; then
    CLIENT_ESCAPED=$(json_escape "$CLIENT_ID")
    PAYLOAD='{"client_id":"'"$CLIENT_ESCAPED"'","command":"'"$CMD_ESCAPED"'","alias":"'"$ALIAS_ESCAPED"'","process_id":'"$PID"'}'
else
    PAYLOAD='{"command":"'"$CMD_ESCAPED"'","alias":"'"$ALIAS_ESCAPED"'","process_id":'"$PID"'}'
fi

# Notify server start
RESPONSE=$(curl -sf -X POST "$SERVER_URL/api/sessions/start" \
  -H "$AUTH_HEADER" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD")
SESSION_ID=$(echo "$RESPONSE" | grep -o '"session_id":[0-9]*' | cut -d: -f2)

# Run user command
"$@"
EXIT_CODE=$?

# Notify server end with retry
for i in 1 2 3; do
    if curl -sf -X POST "$SERVER_URL/api/sessions/$SESSION_ID/end" \
      -H "$AUTH_HEADER" > /dev/null 2>&1; then
        break
    fi
    sleep 2
done

exit $EXIT_CODE
